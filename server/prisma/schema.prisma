datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          String     @id @default(uuid())
  name        String
  description String?
  status      String     @default("ON_TRACK") // ON_TRACK, AT_RISK, DELAYED
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tasks       Task[]
  raidLogs    RaidLog[]
}

model Task {
  id             String    @id @default(uuid())
  projectId      String
  title          String
  description    String?
  status         String    @default("TODO") // TODO, IN_PROGRESS, DONE
  plannedStart   DateTime
  plannedEnd     DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  isMilestone    Boolean   @default(false)
  delayPredicted Boolean   @default(false)
  delayReason    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id])
}

model RaidLog {
  id          String   @id @default(uuid())
  projectId   String
  type        String   // RISK, ASSUMPTION, ISSUE, DEPENDENCY
  description String
  severity    String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("OPEN") // OPEN, MITIGATED, CLOSED
  owner       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
}
